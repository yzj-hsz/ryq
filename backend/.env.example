# 后端环境变量（可选，复制为 .env 由 python-dotenv 加载）
# 应用环境（development / test / production）
APP_ENV=development
ALLOW_PLACEHOLDER_SEED_DATA=true

# 微信小程序（开发环境可通过 WECHAT_ALLOW_MOCK=true 使用占位 openid）
WX_APPID=
WX_SECRET=
WECHAT_ALLOW_MOCK=true

# JWT 签名密钥（生产务必修改）
JWT_SECRET=

# 默认管理员（首次启动无管理员时写入数据库，非接口创建）
# 用户名 admin / 密码 admin123 / 邮箱 admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com

# 邮箱验证码（开发阶段推荐 mock，生产环境改为 smtp）
EMAIL_PROVIDER=mock
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
